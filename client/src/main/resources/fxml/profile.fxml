<AnchorPane prefHeight="350.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bonussystem.client.controller.ProfileController">
    <children>
        <Text layoutX="280.0" layoutY="35.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Профиль" textAlignment="CENTER" wrappingWidth="200.0">
            <font><Font name="Arial" size="24.0" /></font>
        </Text>
        <Text layoutX="20.0" layoutY="80.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Роль:">
            <font><Font name="Arial" size="20.0" /></font>
        </Text>
        <Label fx:id="roleLabel" layoutX="95.0" layoutY="58.0" prefHeight="30.0" prefWidth="230.0">
            <font><Font name="Arial" size="20.0" /></font>
        </Label>
        <Text layoutX="20.0" layoutY="122.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Логин:">
            <font><Font name="Arial" size="20.0" /></font>
        </Text>
        <TextField fx:id="loginField" layoutX="95.0" layoutY="102.0" prefHeight="26.0" prefWidth="230.0" />
