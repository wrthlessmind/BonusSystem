<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="350.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bonussystem.client.controller.LoginController">
   <children>
      <Button layoutX="33.0" layoutY="249.0" mnemonicParsing="false" prefHeight="43.0" prefWidth="282.0" text="Войти" onAction="#handleLogin">
         <font>
            <Font name="Arial" size="24.0" />
         </font>
      </Button>
      <PasswordField fx:id="passwordField" layoutX="27.0" layoutY="183.0" prefHeight="34.0" prefWidth="295.0">
         <font>
            <Font name="Arial" size="18.0" />
         </font>
      </PasswordField>
      <TextField fx:id="loginField" layoutX="27.0" layoutY="113.0" prefHeight="28.0" prefWidth="295.0">
         <font>
            <Font name="Arial" size="18.0" />
         </font>
      </TextField>
      <Text layoutX="25.0" layoutY="35.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Система автоматического расчёта премиальных" textAlignment="CENTER" wrappingWidth="300.0">
         <font>
            <Font name="Arial" size="24.0" />
         </font>
      </Text>
      <Text layoutX="27.0" layoutY="107.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Логин:" wrappingWidth="70.0">
         <font>
            <Font name="Arial" size="20.0" />
         </font>
      </Text>
      <Text layoutX="27.0" layoutY="177.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Пароль:" wrappingWidth="80.0">
         <font>
            <Font name="Arial" size="20.0" />
         </font>
      </Text>
      <Button layoutX="34.0" layoutY="315.0" mnemonicParsing="false" text="Нет учётной записи? Зарегистрируйтесь." textAlignment="CENTER" onAction="#handleGoToRegister">
         <font>
            <Font size="14.0" />
         </font>
      </Button>
   </children>
</AnchorPane>