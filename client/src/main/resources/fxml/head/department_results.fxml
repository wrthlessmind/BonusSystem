<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="750.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bonussystem.client.controller.head.DepartmentResultsController">
    <children>
        <Text layoutX="200.0" layoutY="30.0" strokeType="OUTSIDE" strokeWidth="0.0"
              text="Результаты по отделу" textAlignment="CENTER" wrappingWidth="350.0">
            <font><Font name="Arial" size="20.0"/></font>
        </Text>

        <Text layoutX="12.0" layoutY="56.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Год:">
            <font><Font name="Arial" size="14.0"/></font>
        </Text>
        <TextField fx:id="yearField" layoutX="12.0" layoutY="62.0" prefHeight="26.0"
                   prefWidth="150.0" promptText="Например 2025"/>
        <Button layoutX="172.0" layoutY="62.0" mnemonicParsing="false"
                onAction="#handleLoadResults" prefHeight="26.0" prefWidth="110.0" text="Загрузить">
            <font><Font name="Arial" size="13.0"/></font>
        </Button>

        <TableView fx:id="resultsTable" layoutX="12.0" layoutY="98.0"
                   prefHeight="440.0" prefWidth="726.0">
            <columns>
                <TableColumn fx:id="colEmployeeName" prefWidth="220.0" text="Сотрудник"/>
                <TableColumn fx:id="colKpiScore"     prefWidth="110.0" text="KPI балл"/>
                <TableColumn fx:id="colBonusAmount"  prefWidth="130.0" text="Сумма бонуса"/>
                <TableColumn fx:id="colStatus"       prefWidth="136.0" text="Статус"/>
                <TableColumn fx:id="colComment"      prefWidth="130.0" text="Комментарий"/>
            </columns>
        </TableView>

        <Button layoutX="628.0" layoutY="556.0" mnemonicParsing="false"
                onAction="#handleBack" prefHeight="36.0" prefWidth="110.0" text="Назад">
            <font><Font name="Arial" size="14.0"/></font>
        </Button>
    </children>
</AnchorPane>