<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="620.0" prefWidth="350.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bonussystem.client.controller.RegisterController">
    <children>
        <Text layoutX="25.0" layoutY="35.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Регистрация" textAlignment="CENTER" wrappingWidth="300.0">
            <font><Font name="Arial" size="24.0" /></font>
        </Text>

        <Text layoutX="27.0" layoutY="70.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Логин:">
            <font><Font name="Arial" size="20.0" /></font>
        </Text>
        <TextField fx:id="loginField" layoutX="27.0" layoutY="77.0" prefHeight="34.0" prefWidth="295.0">
            <font><Font name="Arial" size="18.0" /></font>
        </TextField>

        <Text layoutX="27.0" layoutY="135.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Пароль:">
            <font><Font name="Arial" size="20.0" /></font>
        </Text>
        <PasswordField fx:id="passwordField" layoutX="27.0" layoutY="142.0" prefHeight="34.0" prefWidth="295.0">
            <font><Font name="Arial" size="18.0" /></font>
        </PasswordField>

        <Text layoutX="27.0" layoutY="200.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Подтверждение пароля:">
            <font><Font name="Arial" size="20.0" /></font>
        </Text>
        <PasswordField fx:id="confirmPasswordField" layoutX="27.0" layoutY="207.0" prefHeight="34.0" prefWidth="295.0">
            <font><Font name="Arial" size="18.0" /></font>
        </PasswordField>

        <Text layoutX="27.0" layoutY="265.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Имя:">
            <font><Font name="Arial" size="20.0" /></font>
        </Text>
        <TextField fx:id="firstNameField" layoutX="27.0" layoutY="272.0" prefHeight="34.0" prefWidth="295.0">
            <font><Font name="Arial" size="18.0" /></font>
        </TextField>

        <Text layoutX="27.0" layoutY="330.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Фамилия:">
            <font><Font name="Arial" size="20.0" /></font>
        </Text>
        <TextField fx:id="lastNameField" layoutX="27.0" layoutY="337.0" prefHeight="34.0" prefWidth="295.0">
            <font><Font name="Arial" size="18.0" /></font>
        </TextField>

        <Text layoutX="27.0" layoutY="395.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Роль:">
            <font><Font name="Arial" size="20.0" /></font>
        </Text>
        <ComboBox fx:id="roleComboBox" layoutX="27.0" layoutY="402.0" prefHeight="34.0" prefWidth="295.0" />

        <Button layoutX="31.0" layoutY="460.0" mnemonicParsing="false" onAction="#handleRegister" prefHeight="43.0" prefWidth="282.0" text="Зарегистрироваться">
            <font><Font name="Arial" size="24.0" /></font>
        </Button>
        <Button layoutX="31.0" layoutY="515.0" mnemonicParsing="false" onAction="#handleGoToLogin" prefHeight="43.0" prefWidth="282.0" text="Назад">
            <font><Font name="Arial" size="24.0" /></font>
        </Button>
    </children>
</AnchorPane>