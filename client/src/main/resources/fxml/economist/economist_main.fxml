<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="640.0" prefWidth="960.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bonussystem.client.controller.economist.EconomistMainController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color:#2c3e50; -fx-padding:10 20;">
            <Text text="Система расчёта премиальных"
                  strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill:white;">
                <font><Font name="Arial Bold" size="20.0"/></font>
            </Text>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel" style="-fx-text-fill:#bdc3c7;">
                <font><Font name="Arial" size="14.0"/></font>
            </Label>
        </HBox>
    </top>
    <left>
        <VBox prefWidth="210.0" spacing="4"
              style="-fx-background-color:#34495e; -fx-padding:8;">
            <Text text="Экономист по труду" strokeType="OUTSIDE" strokeWidth="0.0"
                  style="-fx-fill:#95a5a6;">
                <font><Font name="Arial" size="11.0"/></font>
            </Text>
            <Separator style="-fx-background-color:#4a6278;"/>
            <Button text="Управление KPI"
                    onAction="#showKpi" maxWidth="Infinity" prefHeight="40.0"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-alignment:CENTER_LEFT; -fx-padding:0 12; -fx-cursor:hand; -fx-background-radius:4;">
                <font><Font name="Arial" size="15.0"/></font>
            </Button>
            <Button text="Управление периодами"
                    onAction="#showPeriods" maxWidth="Infinity" prefHeight="40.0"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-alignment:CENTER_LEFT; -fx-padding:0 12; -fx-cursor:hand; -fx-background-radius:4;">
                <font><Font name="Arial" size="15.0"/></font>
            </Button>
            <Button text="Расчёт премиальных"
                    onAction="#showBonusCalculation" maxWidth="Infinity" prefHeight="40.0"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-alignment:CENTER_LEFT; -fx-padding:0 12; -fx-cursor:hand; -fx-background-radius:4;">
                <font><Font name="Arial" size="15.0"/></font>
            </Button>
            <Button text="Отчёт по премиям"
                    onAction="#showReport" maxWidth="Infinity" prefHeight="40.0"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-alignment:CENTER_LEFT; -fx-padding:0 12; -fx-cursor:hand; -fx-background-radius:4;">
                <font><Font name="Arial" size="15.0"/></font>
            </Button>
            <Button text="Статистика"
                    onAction="#showStatistics" maxWidth="Infinity" prefHeight="40.0"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-alignment:CENTER_LEFT; -fx-padding:0 12; -fx-cursor:hand; -fx-background-radius:4;">
                <font><Font name="Arial" size="15.0"/></font>
            </Button>
            <VBox VBox.vgrow="ALWAYS"/>
            <Separator style="-fx-background-color:#4a6278;"/>
            <Button text="Профиль"
                    onAction="#showProfile" maxWidth="Infinity" prefHeight="40.0"
                    style="-fx-background-color:transparent; -fx-text-fill:white; -fx-alignment:CENTER_LEFT; -fx-padding:0 12; -fx-cursor:hand; -fx-background-radius:4;">
                <font><Font name="Arial" size="15.0"/></font>
            </Button>
            <Button text="Выйти"
                    onAction="#handleLogout" maxWidth="Infinity" prefHeight="40.0"
                    style="-fx-background-color:transparent; -fx-text-fill:#e74c3c; -fx-alignment:CENTER_LEFT; -fx-padding:0 12; -fx-cursor:hand; -fx-background-radius:4;">
                <font><Font name="Arial" size="15.0"/></font>
            </Button>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color:#f0f3f4;"/>
    </center>
</BorderPane>