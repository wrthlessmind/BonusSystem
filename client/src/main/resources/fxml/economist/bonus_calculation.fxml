<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bonussystem.client.controller.economist.BonusCalculationController">
    <children>
        <Text layoutX="220.0" layoutY="36.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Расчёт премий" textAlignment="CENTER" wrappingWidth="310.0">
            <font><Font name="Arial" size="24.0" /></font>
        </Text>

        <Text layoutX="16.0" layoutY="62.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Год:">
            <font><Font name="Arial" size="16.0" /></font>
        </Text>
        <TextField fx:id="yearField" layoutX="16.0" layoutY="69.0" prefWidth="190.0" promptText="Например 2025" />

        <TableView fx:id="calcTable" layoutX="16.0" layoutY="109.0" prefHeight="420.0" prefWidth="718.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="colEmployee" prefWidth="180.0" text="Сотрудник" />
                <TableColumn fx:id="colYear" prefWidth="60.0" text="Год" />
                <TableColumn fx:id="colKpiScore" prefWidth="90.0" text="KPI балл" />
                <TableColumn fx:id="colBonusAmount" prefWidth="110.0" text="Сумма бонуса" />
                <TableColumn fx:id="colStatus" prefWidth="108.0" text="Статус" />
                <TableColumn fx:id="colComment" prefWidth="120.0" text="Комментарий" />
            </columns>
        </TableView>

        <Button layoutX="16.0" layoutY="542.0" mnemonicParsing="false" onAction="#handleCalculate" prefHeight="43.0" prefWidth="160.0" text="Рассчитать">
            <font><Font name="Arial" size="18.0" /></font>
        </Button>
        <Button layoutX="185.0" layoutY="542.0" mnemonicParsing="false" onAction="#handleLoadCalculations" prefHeight="43.0" prefWidth="160.0" text="Загрузить">
            <font><Font name="Arial" size="18.0" /></font>
        </Button>
        <Button layoutX="354.0" layoutY="542.0" mnemonicParsing="false" onAction="#handleApprove" prefHeight="43.0" prefWidth="160.0" text="Утвердить">
            <font><Font name="Arial" size="18.0" /></font>
        </Button>
        <Button layoutX="523.0" layoutY="542.0" mnemonicParsing="false" onAction="#handleReject" prefHeight="43.0" prefWidth="160.0" text="Отклонить">
            <font><Font name="Arial" size="18.0" /></font>
        </Button>
    </children>
</AnchorPane>
