<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bonussystem.client.controller.economist.StatisticsController">
    <children>
        <Text layoutX="205.0" layoutY="36.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Статистика по премиям" textAlignment="CENTER" wrappingWidth="340.8">
            <font><Font name="Arial" size="24.0" /></font>
        </Text>

        <Text layoutX="16.0" layoutY="62.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Год:">
            <font><Font name="Arial" size="16.0" /></font>
        </Text>
        <TextField fx:id="yearField" layoutX="16.0" layoutY="69.0" prefHeight="26.0" prefWidth="190.0" promptText="Например 2025" />

        <Text layoutX="16.0" layoutY="136.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Общая сумма премий:">
            <font><Font name="Arial" size="20.0" /></font>
        </Text>
        <Label fx:id="totalBonusesLabel" layoutX="260.0" layoutY="112.0" prefHeight="34.0" prefWidth="300.0" text="-">
            <font><Font name="Arial" size="20.0" /></font>
        </Label>

        <Text layoutX="16.0" layoutY="196.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Средний бонус:">
            <font><Font name="Arial" size="20.0" /></font>
        </Text>
        <Label fx:id="avgBonusLabel" layoutX="260.0" layoutY="172.0" prefHeight="34.0" prefWidth="300.0" text="-">
            <font><Font name="Arial" size="20.0" /></font>
        </Label>

        <Text layoutX="16.0" layoutY="256.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Максимальный KPI:">
            <font><Font name="Arial" size="20.0" /></font>
        </Text>
        <Label fx:id="maxKpiLabel" layoutX="260.0" layoutY="232.0" prefHeight="34.0" prefWidth="300.0" text="-">
            <font><Font name="Arial" size="20.0" /></font>
        </Label>

        <Text layoutX="16.0" layoutY="316.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Минимальный KPI:">
            <font><Font name="Arial" size="20.0" /></font>
        </Text>
        <Label fx:id="minKpiLabel" layoutX="260.0" layoutY="292.0" prefHeight="34.0" prefWidth="300.0" text="-">
            <font><Font name="Arial" size="20.0" /></font>
        </Label>

        <Text layoutX="16.0" layoutY="375.0" strokeType="OUTSIDE" strokeWidth="0.0" text="\% достигших цели:">
            <font><Font name="Arial" size="20.0" /></font>
        </Text>
        <Label fx:id="achievedPercentLabel" layoutX="260.0" layoutY="352.0" prefHeight="34.0" prefWidth="300.0" text="-">
            <font><Font name="Arial" size="20.0" /></font>
        </Label>

        <Button layoutX="14.0" layoutY="542.0" mnemonicParsing="false" onAction="#handleLoadStatistics" prefHeight="43.0" prefWidth="179.0" text="Загрузить">
            <font><Font name="Arial" size="18.0" /></font>
        </Button>
    </children>
</AnchorPane>
