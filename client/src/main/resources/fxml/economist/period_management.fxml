<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bonussystem.client.controller.economist.PeriodManagementController">
    <children>
        <Text layoutX="205.0" layoutY="36.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Управление периодами" textAlignment="CENTER" wrappingWidth="340.8">
            <font><Font name="Arial" size="24.0" /></font>
        </Text>

        <TableView fx:id="periodTable" layoutX="16.0" layoutY="54.0" prefHeight="474.0" prefWidth="554.0">
            <columns>
                <TableColumn fx:id="colYear" prefWidth="100.0" text="Год" />
                <TableColumn fx:id="colBonusFund" prefWidth="230.0" text="Премиальный фонд" />
                <TableColumn fx:id="colStatus" prefWidth="224.0" text="Статус" />
            </columns>
        </TableView>

        <Text layoutX="16.0" layoutY="553.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Год:">
            <font><Font name="Arial" size="16.0" /></font>
        </Text>
        <TextField fx:id="yearField" layoutX="16.0" layoutY="559.0" prefHeight="26.0" prefWidth="179.0" />

        <Text layoutX="205.0" layoutY="553.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Премиальный фонд:">
            <font><Font name="Arial" size="16.0" /></font>
        </Text>
        <TextField fx:id="bonusFundField" layoutX="205.0" layoutY="559.0" prefHeight="26.0" prefWidth="179.0" />

        <Button layoutX="580.0" layoutY="54.0" mnemonicParsing="false" onAction="#handleAdd" prefHeight="43.0" prefWidth="154.0" text="Добавить">
            <font><Font name="Arial" size="18.0" /></font>
        </Button>
        <Button layoutX="580.0" layoutY="110.0" mnemonicParsing="false" onAction="#handleUpdate" prefHeight="43.0" prefWidth="154.0" text="Изменить">
            <font><Font name="Arial" size="18.0" /></font>
        </Button>
        <Button layoutX="580.0" layoutY="166.0" mnemonicParsing="false" onAction="#handleDelete" prefHeight="43.0" prefWidth="154.0" text="Удалить">
            <font><Font name="Arial" size="18.0" /></font>
        </Button>
        <Button layoutX="580.0" layoutY="222.0" mnemonicParsing="false" onAction="#handleRefresh" prefHeight="43.0" prefWidth="154.0" text="Обновить">
            <font><Font name="Arial" size="18.0" /></font>
        </Button>
    </children>
</AnchorPane>
