<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bonussystem.client.controller.hr.EmployeeManagementController">
    <children>

        <Text layoutX="226.0" layoutY="36.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Управление сотрудниками" textAlignment="CENTER">
            <font><Font name="Arial" size="24.0" /></font>
        </Text>

        <TableView fx:id="employeeTable" layoutX="14.0" layoutY="50.0" prefHeight="425.0" prefWidth="722.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="colFullName" prefWidth="210.0" text="Сотрудник" />
                <TableColumn fx:id="colPosition" prefWidth="155.0" text="Должность" />
                <TableColumn fx:id="colSalary" prefWidth="107.0" text="Оклад" />
                <TableColumn fx:id="colDeptId" prefWidth="200.0" text="Отдел" />
            </columns>
        </TableView>

        <Label layoutX="15.0" layoutY="486.0" text="Имя:">
            <font><Font name="Arial" size="14.0" /></font>
        </Label>
        <TextField fx:id="firstNameField" layoutX="15.0" layoutY="506.0" prefWidth="120.0" />

        <Label layoutX="145.0" layoutY="486.0" text="Фамилия:">
            <font><Font name="Arial" size="14.0" /></font>
        </Label>
        <TextField fx:id="lastNameField" layoutX="145.0" layoutY="506.0" prefWidth="120.0" />

        <Label layoutX="275.0" layoutY="486.0" text="Должность:">
            <font><Font name="Arial" size="14.0" /></font>
        </Label>
        <TextField fx:id="positionField" layoutX="275.0" layoutY="506.0" prefWidth="120.0" />

        <Label layoutX="405.0" layoutY="486.0" text="Оклад:">
            <font><Font name="Arial" size="14.0" /></font>
        </Label>
        <TextField fx:id="salaryField" layoutX="405.0" layoutY="506.0" prefWidth="100.0" />

        <Label layoutX="515.0" layoutY="486.0" text="Отдел:">
            <font><Font name="Arial" size="14.0" /></font>
        </Label>
        <ComboBox fx:id="deptComboBox" layoutX="515.0" layoutY="506.0" prefWidth="220.0" />

        <Button layoutX="15.0" layoutY="546.0" mnemonicParsing="false" onAction="#handleAdd" prefHeight="40.0" prefWidth="130.0" text="Добавить">
            <font><Font name="Arial" size="14.0" /></font>
        </Button>
        <Button layoutX="155.0" layoutY="546.0" mnemonicParsing="false" onAction="#handleUpdate" prefHeight="40.0" prefWidth="130.0" text="Изменить">
            <font><Font name="Arial" size="14.0" /></font>
        </Button>
        <Button layoutX="295.0" layoutY="546.0" mnemonicParsing="false" onAction="#handleDelete" prefHeight="40.0" prefWidth="130.0" text="Удалить">
            <font><Font name="Arial" size="14.0" /></font>
        </Button>
        <Button layoutX="435.0" layoutY="546.0" mnemonicParsing="false" onAction="#handleRefresh" prefHeight="40.0" prefWidth="150.0" text="Обновить список">
            <font><Font name="Arial" size="14.0" /></font>
        </Button>

    </children>
</AnchorPane>