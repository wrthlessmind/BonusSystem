<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bonussystem.client.controller.hr.DepartmentManagementController">
    <children>
        <Text layoutX="205.0" layoutY="36.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Управление отделами" textAlignment="CENTER" wrappingWidth="340.0">
            <font><Font name="Arial" size="24.0" /></font>
        </Text>

        <TableView fx:id="departmentTable" layoutX="16.0" layoutY="54.0" prefHeight="470.0" prefWidth="550.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="61.6" text="ID" />
                <TableColumn fx:id="colName" prefWidth="280.0" text="Название" />
                <TableColumn fx:id="colHeadUserId" prefWidth="208.0" text="Руководитель отдела" />
            </columns>
        </TableView>

        <Text layoutX="16.0" layoutY="553.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Название отдела:">
            <font><Font name="Arial" size="16.0" /></font>
        </Text>
        <TextField fx:id="nameField" layoutX="16.0" layoutY="559.0" prefHeight="26.0" prefWidth="212.0" />

        <Text layoutX="252.0" layoutY="553.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Руководитель отдела:">
            <font><Font name="Arial" size="16.0" /></font>
        </Text>
        <ComboBox fx:id="headUserComboBox" layoutX="252.0" layoutY="559.0" prefHeight="26.0" prefWidth="230.0" />

        <Button layoutX="580.0" layoutY="54.0" mnemonicParsing="false" onAction="#handleAdd" prefHeight="43.0" prefWidth="155.0" text="Добавить">
            <font><Font name="Arial" size="16.0" /></font>
        </Button>
        <Button layoutX="580.0" layoutY="110.0" mnemonicParsing="false" onAction="#handleUpdate" prefHeight="43.0" prefWidth="155.0" text="Изменить">
            <font><Font name="Arial" size="16.0" /></font>
        </Button>
        <Button layoutX="580.0" layoutY="166.0" mnemonicParsing="false" onAction="#handleDelete" prefHeight="43.0" prefWidth="155.0" text="Удалить">
            <font><Font name="Arial" size="16.0" /></font>
        </Button>
        <Button layoutX="580.0" layoutY="222.0" mnemonicParsing="false" onAction="#handleRefresh" prefHeight="43.0" prefWidth="155.0" text="Обновить">
            <font><Font name="Arial" size="16.0" /></font>
        </Button>
    </children>
</AnchorPane>
